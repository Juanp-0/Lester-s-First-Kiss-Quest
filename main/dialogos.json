{
    "intro": [
        {
            "tipo": "narracion",
            "texto": "Esta es una historia de cuatro amigos, Lester, Dax, Hugh y Zohan"
        },
        {
            "tipo": "narracion",
            "texto": "Son cuatro chicos de 19 años, quienes se conocen desde la secundaria"
        },
        {
            "tipo": "narracion",
            "texto": "En la noche de año nuevo, Zohan se acordo de algo que le dijo Lester"
        },
        {
            "tipo": "narracion",
            "texto": "Una promesa, que tiene que cumplir en el presente año"
        },
        {
            "tipo": "narracion",
            "texto": "Por lo que rapidamente, Zohan toma su celular y decide hablar en el chat grupal de los amigos"
        },
        {
            "tipo": "separador",
            "texto": "1 de Enero de 2015 - 12:30 am - Chat Grupal"
        },
        {
            "tipo": "dialogo",
            "personaje": "Zohan",
            "texto": "@todos"
        },
        {
            "tipo": "dialogo",
            "personaje": "Zohan",
            "texto": "Tengo un anuncio importante que dar"
        },
        {
            "tipo": "dialogo",
            "personaje": "Dax",
            "texto": "¿Que Paso?"
        },
        {
            "tipo": "dialogo",
            "personaje": "Dax",
            "texto": "Me estaba durmiendo"
        },
        {
            "tipo": "dialogo",
            "personaje": "Zohan",
            "texto": "Me acordé de algo de suma importancia"
        },
        {
            "tipo": "dialogo",
            "personaje": "Zohan",
            "texto": "Es que no se si hacerlo más al rato"
        },
        {
            "tipo": "dialogo",
            "personaje": "Zohan",
            "texto": "Porque necesito especialmente a Lester disponible"
        },
        {
            "tipo": "dialogo",
            "personaje": "Lester",
            "texto": "Aqui estoy"
        },
        {
            "tipo": "dialogo",
            "personaje": "Lester",
            "texto": "Dilo de una vez"
        },
        {
            "tipo": "dialogo",
            "personaje": "Zohan",
            "texto": "Okey"
        },
        {
            "tipo": "dialogo",
            "personaje": "Zohan",
            "texto": "@todos"
        },
        {
            "tipo": "dialogo",
            "personaje": "Zohan",
            "texto": "Primero que nada"
        },
        {
            "tipo": "dialogo",
            "personaje": "Zohan",
            "texto": "Feliz 2015"
        },
        {
            "tipo": "dialogo",
            "personaje": "Zohan",
            "texto": "Ya es 2015"
        },
        {
            "tipo": "dialogo",
            "personaje": "Zohan",
            "texto": "Y quiero hacerle un amable recordatorio a mi amigo Lester"
        },
        {
            "tipo": "dialogo",
            "personaje": "Zohan",
            "texto": "Ya que dijo que haría algo especial este año"
        },
        {
            "tipo": "dialogo",
            "personaje": "Hugh",
            "texto": "Al fin sacaras a Lester del Grupo?"
        },
        {
            "tipo": "dialogo",
            "personaje": "Zohan",
            "texto": "Nop"
        },
        {
            "tipo": "dialogo",
            "personaje": "Zohan",
            "texto": "Mi buen amigo Lester comento algo el 16 de agosto de 2013 a las 7:43 pm"
        },
        {
            "tipo": "dialogo",
            "personaje": "Zohan",
            "texto": "y cito"
        },
        {
            "tipo": "separador",
            "texto": "16 de Agosto de 2013 - 19:43 pm - Chat Grupal"
        },
        {
            "tipo": "dialogo",
            "personaje": "Lester",
            "texto": "Aunque claro aún tengo presente el plan por si no doy mi primer beso antes de los 20"
        },
        {
            "tipo": "dialogo",
            "personaje": "Lester",
            "texto": "Ir a una convención"
        },
        {
            "tipo": "dialogo",
            "personaje": "Lester",
            "texto": "Ver a una cosplayer de chica anime"
        },
        {
            "tipo": "dialogo",
            "personaje": "Lester",
            "texto": "y ofrecerle unos $2000 para que me de un beso"
        },
        {
            "tipo": "dialogo",
            "personaje": "Lester",
            "texto": "con todo respeto"
        },
        {
            "tipo": "separador",
            "texto": "1 de Enero de 2015 - 01:00 am - Chat Grupal"
        },
        {
            "tipo": "dialogo",
            "personaje": "Dax",
            "texto": "XD"
        },
        {
            "tipo": "dialogo",
            "personaje": "Dax",
            "texto": "Ya se por donde va esto"
        },
        {
            "tipo": "dialogo",
            "personaje": "Zohan",
            "texto": "Tic Tac Lester Tic Tac"
        },
        {
            "tipo": "dialogo",
            "personaje": "Lester",
            "texto": "Se cancela"
        },
        {
            "tipo": "dialogo",
            "personaje": "Lester",
            "texto": "Ni siquiera recordaba haber dicho eso"
        },
        {
            "tipo": "dialogo",
            "personaje": "Hugh",
            "texto": "XD"
        },
        {
            "tipo": "dialogo",
            "personaje": "Hugh",
            "texto": "Eres un reverendo pendejo Lester"
        },
        {
            "tipo": "dialogo",
            "personaje": "Zohan",
            "texto": "No Lester"
        },
        {
            "tipo": "dialogo",
            "personaje": "Zohan",
            "texto": "Ya no hay vuelta atrás"
        },
        {
            "tipo": "dialogo",
            "personaje": "Zohan",
            "texto": "Te quedan 50 días Lester"
        },
        {
            "tipo": "dialogo",
            "personaje": "Zohan",
            "texto": "Lo que quedaba de 2013 no hiciste nada"
        },
        {
            "tipo": "dialogo",
            "personaje": "Zohan",
            "texto": "y en 2014 tampoco"
        },
        {
            "tipo": "dialogo",
            "personaje": "Zohan",
            "texto": "Y ya solo te quedan menos de 2 meses Lester"
        },
        {
            "tipo": "dialogo",
            "personaje": "Zohan",
            "texto": "El tiempo corre"
        },
        {
            "tipo": "narracion",
            "texto": "Lester cumple 20 años dentro de 50 dias"
        },
        {
            "tipo": "narracion",
            "texto": "Asi que como dijo Zohan"
        },
        {
            "tipo": "narracion",
            "texto": "EL TIEMPO CORRE"
        }
